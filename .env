# Check README.md step 6 (OCI CLI profile name, default is "DEFAULT")
PROFILE="DEFAULT"
# Go to Profile -> Tenancy (Tenancy information OCID) and copy it here
TENANCY_ID="ocid1.tenancy.oc1..***"
# Check README.md step 7
IMAGE_ID="ocid1.image.oc1.***.***"
# Check README.md step 8
SUBNET_ID="ocid1.subnet.oc1.***.***"
# Check README.md step 9
AVAILABILITY_DOMAIN="JtDP:***"
# Check README.md step 10
PATH_TO_PUBLIC_SSH_KEY="/app/oracle-arm-ssh.key.pub"

# VM parameters
CPUs=4 # max 4 cores for all Arm-based VM shapes
RAM=24 # max 24 GB for all Arm-based VM shapes
BOOT_VOLUME=100 # in GB, max 200 GB for all Arm-based VM shapes

# Scheduling parameters
REQUEST_INTERVAL=60 # seconds between each request
BACKOFF_TIME=300 # seconds to wait after hitting a rate limit or error before retrying